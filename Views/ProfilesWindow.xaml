<Window x:Class="MXFConverter.Views.ProfilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profils de conversion"
        Width="680" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimary}"
        Foreground="{StaticResource TextPrimary}"
        WindowStyle="None" AllowsTransparency="True">

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <!-- Titre -->
            <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                    CornerRadius="10,10,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x1F4CB;" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Profils de conversion" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="+ Nouveau profil" Style="{StaticResource PrimaryButton}"
                                Padding="12,6" FontSize="11" Margin="0,0,8,0" Click="BtnNewProfile_Click"/>
                        <Button Content="&#x2715;" Width="32" Height="28" Background="Transparent"
                                BorderThickness="0" Foreground="{StaticResource TextSecondary}"
                                Cursor="Hand" Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Liste profils -->
            <ScrollViewer Grid.Row="1" Margin="16">
                <ItemsControl x:Name="ProfilesList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="190" Background="{StaticResource BgCard}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="8"
                                    Margin="0,0,8,8" Padding="14,12"
                                    Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                                <Setter Property="Background"  Value="{StaticResource BgHover}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding Icon}" FontSize="22"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                            <Border Background="#1A2540" CornerRadius="3" Padding="5,1"
                                                    HorizontalAlignment="Left" Margin="0,3,0,0">
                                                <TextBlock Text="{Binding OutputFormat}"
                                                           Foreground="{StaticResource AccentBlue}"
                                                           FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{StaticResource PrimaryButton}" Padding="10,5"
                                                FontSize="10" Tag="{Binding Id}"
                                                Click="BtnApplyProfile_Click" Margin="0,0,4,0">
                                            Appliquer
                                        </Button>
                                        <Button Style="{StaticResource SecondaryButton}" Padding="8,5"
                                                FontSize="10" Tag="{Binding Id}"
                                                Click="BtnDeleteProfile_Click"
                                                Visibility="{Binding IsBuiltIn, Converter={StaticResource InverseBoolVisibility}}">
                                            &#x2715;
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Bas -->
            <Border Grid.Row="2" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="16,0">
                    <Button Content="Fermer" Style="{StaticResource SecondaryButton}" Click="BtnClose_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
