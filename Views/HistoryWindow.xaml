<Window x:Class="MXFConverter.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historique — MXF Converter Pro"
        Width="860" Height="540"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimary}"
        Foreground="{StaticResource TextPrimary}"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="44"/>
            </Grid.RowDefinitions>

            <!-- Titre -->
            <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                    CornerRadius="10,10,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x1F4DC;" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Historique des conversions" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <Border x:Name="CountBadge" Background="{StaticResource AccentBlue}"
                                CornerRadius="10" Padding="8,2" Margin="10,0,0,0">
                            <TextBlock x:Name="TxtCount" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <Button Content="&#x2715;" HorizontalAlignment="Right" Width="32" Height="28"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextSecondary}" Cursor="Hand"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- Liste -->
            <Grid Grid.Row="1" Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- En-têtes -->
                <Grid Grid.Row="0" Margin="8,0,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text=""
                               Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="FICHIER"
                               Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="FORMAT"
                               Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Grid.Column="3" Text="TAILLE ENT."
                               Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Grid.Column="4" Text="TAILLE SORT."
                               Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Grid.Column="5" Text="DUR&#201;E"
                               Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Grid.Column="6" Text="TEMPS"
                               Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                    <TextBlock Grid.Column="7" Text="DATE"
                               Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                </Grid>

                <ScrollViewer Grid.Row="1">
                    <ListBox x:Name="HistoryList" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgCard}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        Margin="0,0,0,4" Padding="8,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="130"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Statut -->
                                        <TextBlock Grid.Column="0" Text="{Binding StatusIcon}"
                                                   Foreground="{Binding StatusColor}"
                                                   FontSize="14" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        <!-- Nom fichier -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="12" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding ErrorMessage}"
                                                       Foreground="{StaticResource AccentRed}"
                                                       FontSize="10" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding OutputFormat}"
                                                   Foreground="{StaticResource AccentBlue}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding InputSizeFmt}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding OutputSizeFmt}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5"
                                                   Text="{Binding DurationFmt}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="6"
                                                   Text="{Binding ConvTimeFmt}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="7"
                                                   Text="{Binding DateFormatted}"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- Message vide -->
                <TextBlock x:Name="EmptyMsg" Grid.Row="1"
                           Text="Aucune conversion dans l'historique"
                           Foreground="{StaticResource TextMuted}" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>

            <!-- Bas -->
            <Border Grid.Row="2" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10">
                <Grid Margin="16,0">
                    <TextBlock x:Name="TxtStats" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Vider l'historique" Style="{StaticResource DangerButton}"
                                Margin="0,0,8,0" Click="BtnClear_Click"/>
                        <Button Content="Fermer" Style="{StaticResource SecondaryButton}"
                                Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
