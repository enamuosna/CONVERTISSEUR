<Window x:Class="MXFConverter.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Statistiques — MXF Converter Pro"
        Width="900" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimary}"
        Foreground="{StaticResource TextPrimary}"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Titre -->
            <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x1F4CA;" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Statistiques de conversion" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="&#x2715;" HorizontalAlignment="Right" Width="32" Height="28"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextSecondary}" Cursor="Hand"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- Corps -->
            <ScrollViewer Grid.Row="1" Margin="0">
                <StackPanel Margin="20">

                    <!-- ── KPI CARDS ── -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Total conversions" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                <TextBlock x:Name="KpiTotal" Text="0" FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBlue}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="KpiTotalSub" Text="fichiers traités" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Taux de succ&#232;s" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                <TextBlock x:Name="KpiSuccess" Text="0%" FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGreen}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="KpiSuccessSub" Text="0 réussies / 0 erreurs" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Donn&#233;es trait&#233;es" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                <TextBlock x:Name="KpiData" Text="0 MB" FontSize="32" FontWeight="Bold"
                                           Foreground="#A78BFA" Margin="0,4,0,0"/>
                                <TextBlock x:Name="KpiDataSub" Text="0 MB en sortie" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6" Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Temps moyen" Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                <TextBlock x:Name="KpiTime" Text="0s" FontSize="32" FontWeight="Bold"
                                           Foreground="{StaticResource AccentOrange}" Margin="0,4,0,0"/>
                                <TextBlock x:Name="KpiTimeSub" Text="par fichier" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ── ROW 2 : Formats bar chart + Succès donut ── -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <!-- Bar chart formats -->
                        <Border Grid.Column="0" Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Formats de sortie utilis&#233;s" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>
                                <Canvas x:Name="BarChart" Grid.Row="1" Height="180" Background="Transparent"/>
                            </Grid>
                        </Border>

                        <!-- Donut Succès/Erreurs -->
                        <Border Grid.Column="2" Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Succ&#232;s vs Erreurs" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                                <Canvas x:Name="DonutChart" Grid.Row="1" Height="180" Background="Transparent"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ── ROW 3 : Compression + Timeline ── -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Compression moyenne par format -->
                        <Border Grid.Column="0" Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Compression moyenne par format (%)" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>
                                <Canvas x:Name="CompressionChart" Grid.Row="1" Height="150" Background="Transparent"/>
                            </Grid>
                        </Border>

                        <!-- Top fichiers les plus lourds traités -->
                        <Border Grid.Column="2" Background="{StaticResource BgCard}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Top 5 — fichiers les plus volumineux" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>
                                <ItemsControl x:Name="TopFilesPanel" Grid.Row="1"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ── Boutons export ── -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource SecondaryButton}" Click="BtnExportCsv_Click" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4E5;" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Exporter CSV" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Click="BtnExportTxt_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4C4;" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Exporter rapport .txt" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
