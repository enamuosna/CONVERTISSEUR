<Window x:Class="MXFConverter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MXFConverter.Models"
        Title="MXF Converter Pro"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimary}"
        Foreground="{StaticResource TextPrimary}"
        WindowStyle="None"
        AllowsTransparency="True"
        Drop="Window_Drop"
        AllowDrop="True">

    <Window.Resources>
        <!-- Convertisseur status couleur -->
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width"  Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>   <!-- Barre titre -->
                <RowDefinition Height="64"/>   <!-- Barre outils -->
                <RowDefinition Height="*"/>    <!-- Contenu principal -->
                <RowDefinition Height="Auto"/> <!-- Barre de statut -->
            </Grid.RowDefinitions>

            <!-- ===== BARRE DE TITRE CUSTOM ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgSecondary}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Logo / Icône -->
                        <Border Width="28" Height="28" Background="{StaticResource AccentBlue}"
                                CornerRadius="6" Margin="0,0,12,0">
                            <TextBlock Text="▶" Foreground="White" FontSize="12"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="MXF Converter Pro"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Border Background="#1A2540" CornerRadius="4" Margin="12,0,0,0" Padding="6,2">
                            <TextBlock Text="v1.0" Foreground="{StaticResource AccentBlue}" FontSize="10"/>
                        </Border>
                    </StackPanel>

                    <!-- Boutons fenêtre -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnMinimize" Content="─" Width="36" Height="28"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondary}" FontSize="12"
                                Cursor="Hand" Click="BtnMinimize_Click"/>
                        <Button x:Name="BtnMaximize" Content="□" Width="36" Height="28"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondary}" FontSize="12"
                                Cursor="Hand" Click="BtnMaximize_Click"/>
                        <Button x:Name="BtnClose" Content="✕" Width="36" Height="28"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondary}" FontSize="12"
                                Cursor="Hand" Click="BtnClose_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#C0392B"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== BARRE D'OUTILS ===== -->
            <Border Grid.Row="1" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">

                        <!-- Ajouter fichiers -->
                        <Button Style="{StaticResource PrimaryButton}"
                                Click="BtnAddFiles_Click" Padding="16,9">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="Ajouter fichiers" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Ajouter dossier -->
                        <Button Style="{StaticResource SecondaryButton}"
                                Click="BtnAddFolder_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="📁" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Dossier" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Width="1" Height="28" Margin="4,0"/>

                        <!-- Format de sortie global -->
                        <TextBlock Text="Format :" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                        <ComboBox x:Name="CmbGlobalFormat" Width="100"
                                  SelectionChanged="CmbGlobalFormat_SelectionChanged"/>

                        <!-- Qualité globale -->
                        <TextBlock Text="Qualité :" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="8,0,0,0"/>
                        <ComboBox x:Name="CmbGlobalQuality" Width="140"
                                  SelectionChanged="CmbGlobalQuality_SelectionChanged"/>

                        <Separator Width="1" Height="28" Margin="4,0"/>

                        <!-- Répertoire sortie -->
                        <Button Style="{StaticResource SecondaryButton}" Click="BtnOutputDir_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="📂" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Sortie" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="TxtOutputDir" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondary}" FontSize="11"
                                   MaxWidth="200" TextTrimming="CharacterEllipsis"/>

                    </StackPanel>

                    <!-- Boutons droite -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Spacing="8">
                        <Button Style="{StaticResource SecondaryButton}" Click="BtnClearAll_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="🗑" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="Vider" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnConvertAll" Style="{StaticResource PrimaryButton}"
                                Click="BtnConvertAll_Click" Padding="20,9">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="⚡" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Tout convertir" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== ZONE PRINCIPALE ===== -->
            <Grid Grid.Row="2">
                <!-- Zone de drop (visible si liste vide) -->
                <Border x:Name="DropZone" Background="Transparent"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="2" CornerRadius="12" Margin="24"
                        Visibility="Visible">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                    <Setter Property="Background" Value="#0A1A3A"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <!-- Contenu drop zone -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                        <Border Width="80" Height="80" Background="#1A2540" CornerRadius="40"
                                HorizontalAlignment="Center">
                            <TextBlock Text="🎬" FontSize="36"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Glissez vos fichiers ici"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Foreground="{StaticResource TextSecondary}"
                                   FontSize="13" HorizontalAlignment="Center">
                            <Run Text="Formats supportés : "/>
                            <Run Text="MXF, MP4, MOV, MKV, AVI, WMV, FLV..." Foreground="{StaticResource AccentBlue}"/>
                        </TextBlock>
                        <Button Style="{StaticResource PrimaryButton}"
                                Click="BtnAddFiles_Click" HorizontalAlignment="Center"
                                Margin="0,8,0,0">
                            Parcourir les fichiers
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Liste des fichiers -->
                <Grid x:Name="FileListPanel" Visibility="Collapsed" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- En-tête liste -->
                    <Grid Grid.Row="0" Margin="8,0,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="FICHIER" Style="{StaticResource {x:Type TextBlock}}"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="TAILLE"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="DURÉE"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="FORMAT SORTIE"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="QUALITÉ"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="5" Text="PROGRESSION"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="6" Text="ACTIONS"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                    </Grid>

                    <!-- Liste scrollable -->
                    <ScrollViewer Grid.Row="1">
                        <ListBox x:Name="FileListBox" Background="Transparent"
                                 BorderThickness="0" Padding="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ConversionItem}">
                                    <Border Background="{StaticResource BgCard}"
                                            CornerRadius="8" Margin="0,0,0,6"
                                            Padding="8,10" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="110"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Nom fichier + info -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border Background="#1A2540" CornerRadius="4"
                                                            Padding="5,2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding FileExtension}"
                                                                   Foreground="{StaticResource AccentBlue}"
                                                                   FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding FileName}"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontSize="13" FontWeight="Medium"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding VideoInfo}"
                                                           Foreground="{StaticResource TextMuted}"
                                                           FontSize="10" Margin="0,3,0,0"/>
                                            </StackPanel>

                                            <!-- Taille -->
                                            <TextBlock Grid.Column="1" Text="{Binding FileSizeFormatted}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="12"/>

                                            <!-- Durée -->
                                            <TextBlock Grid.Column="2" Text="{Binding DurationFormatted}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="12"/>

                                            <!-- Format sortie -->
                                            <ComboBox Grid.Column="3" Width="100"
                                                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.Formats}"
                                                      SelectedItem="{Binding OutputFormat, Mode=TwoWay}"
                                                      VerticalAlignment="Center" FontSize="11"/>

                                            <!-- Qualité -->
                                            <ComboBox Grid.Column="4" Width="120"
                                                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.QualityPresets}"
                                                      SelectedItem="{Binding QualityPreset, Mode=TwoWay}"
                                                      VerticalAlignment="Center" FontSize="11"/>

                                            <!-- Progression -->
                                            <StackPanel Grid.Column="5" VerticalAlignment="Center" Spacing="4">
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Ellipse Style="{StaticResource StatusDot}"
                                                                 Fill="{Binding StatusColor}"/>
                                                        <TextBlock Text="{Binding ProgressText}"
                                                                   FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{Binding StatusColor}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <ProgressBar Value="{Binding Progress}" Maximum="100"/>
                                                <TextBlock Text="{Binding StatusMessage}"
                                                           FontSize="9" Foreground="{StaticResource TextMuted}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- Actions -->
                                            <StackPanel Grid.Column="6" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Spacing="4">
                                                <!-- Convertir -->
                                                <Button Style="{StaticResource SecondaryButton}"
                                                        Padding="8,5" FontSize="11"
                                                        IsEnabled="{Binding CanConvert}"
                                                        Tag="{Binding Id}"
                                                        Click="BtnConvertOne_Click">
                                                    ▶
                                                </Button>
                                                <!-- Annuler -->
                                                <Button Style="{StaticResource SecondaryButton}"
                                                        Padding="8,5" FontSize="11"
                                                        IsEnabled="{Binding CanCancel}"
                                                        Tag="{Binding Id}"
                                                        Click="BtnCancelOne_Click">
                                                    ■
                                                </Button>
                                                <!-- Supprimer -->
                                                <Button Style="{StaticResource DangerButton}"
                                                        Padding="8,5" FontSize="11"
                                                        Tag="{Binding Id}"
                                                        Click="BtnRemoveOne_Click">
                                                    ✕
                                                </Button>
                                            </StackPanel>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <!-- Résumé en bas -->
                    <Border Grid.Row="2" Background="{StaticResource BgCard}"
                            CornerRadius="8" Padding="16,10" Margin="0,8,0,0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="📄" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtTotalFiles"
                                               Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreen}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtCompleted"
                                               Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentOrange}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtPending"
                                               Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentRed}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtErrors"
                                               Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Progression globale -->
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="12">
                                <TextBlock x:Name="TxtGlobalProgress"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                <ProgressBar x:Name="GlobalProgressBar" Width="200"
                                             Maximum="100" Height="8"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ===== BARRE DE STATUT ===== -->
            <Border Grid.Row="3" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12" Padding="16,8">
                <Grid>
                    <TextBlock x:Name="TxtStatus" Text="Prêt — Glissez des fichiers ou cliquez sur Ajouter"
                               Foreground="{StaticResource TextMuted}" FontSize="11"
                               VerticalAlignment="Center"/>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="FFmpeg Engine" Foreground="{StaticResource TextMuted}" FontSize="10"
                                   VerticalAlignment="Center"/>
                        <Ellipse x:Name="FFmpegStatusDot" Width="7" Height="7"
                                 Fill="{StaticResource AccentGreen}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
