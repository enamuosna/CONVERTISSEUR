<Window x:Class="MXFConverter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MXFConverter.Models"
        Title="MXF Converter Pro"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimary}"
        Foreground="{StaticResource TextPrimary}"
        WindowStyle="None"
        AllowsTransparency="True"
        Drop="Window_Drop"
        AllowDrop="True">

    <Window.Resources>
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width"  Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== BARRE DE TITRE CUSTOM ===== -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgSecondary}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="28" Height="28" Background="{StaticResource AccentBlue}"
                                CornerRadius="6" Margin="0,0,12,0">
                            <TextBlock Text="&#x25B6;" Foreground="White" FontSize="12"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="MXF Converter Pro"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Border Background="#1A2540" CornerRadius="4" Padding="6,2">
                            <TextBlock Text="v1.0" Foreground="{StaticResource AccentBlue}" FontSize="10"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="BtnMinimize" Content="&#x2500;" Width="36" Height="28"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondary}" FontSize="12"
                                Cursor="Hand" Click="BtnMinimize_Click"/>
                        <Button x:Name="BtnMaximize" Content="&#x25A1;" Width="36" Height="28"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextSecondary}" FontSize="12"
                                Cursor="Hand" Click="BtnMaximize_Click"/>
                        <Button x:Name="BtnClose" Content="&#x2715;" Width="36" Height="28"
                                Foreground="{StaticResource TextSecondary}" FontSize="12"
                                Cursor="Hand" Click="BtnClose_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#C0392B"/>
                                                        <Setter Property="Foreground"  Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== BARRE D'OUTILS ===== -->
            <Border Grid.Row="1" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="16,0">
                    <!-- Gauche -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource PrimaryButton}"
                                Click="BtnAddFiles_Click" Padding="16,9" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Ajouter fichiers" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SecondaryButton}"
                                Click="BtnAddFolder_Click" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4C1;" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Dossier" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Separator Width="1" Height="28" Margin="4,0,12,0"/>

                        <TextBlock Text="Format :" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="12" Margin="0,0,8,0"/>
                        <ComboBox x:Name="CmbGlobalFormat" Width="100" Margin="0,0,12,0"
                                  SelectionChanged="CmbGlobalFormat_SelectionChanged"/>

                        <TextBlock Text="Qualit&#233; :" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="12" Margin="0,0,8,0"/>
                        <ComboBox x:Name="CmbGlobalQuality" Width="140" Margin="0,0,8,0"
                                  SelectionChanged="CmbGlobalQuality_SelectionChanged"/>

                        <Separator Width="1" Height="28" Margin="4,0,12,0"/>

                        <Button Style="{StaticResource SecondaryButton}"
                                Click="BtnOutputDir_Click" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4C2;" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Sortie" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="TxtOutputDir" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11" MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Droite -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource SecondaryButton}"
                                Click="BtnClearAll_Click" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F5D1;" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Vider" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnConvertAll" Style="{StaticResource PrimaryButton}"
                                Click="BtnConvertAll_Click" Padding="20,9">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x26A1;" FontSize="13"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Tout convertir" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== ZONE PRINCIPALE ===== -->
            <Grid Grid.Row="2">
                <!-- Drop zone (liste vide) -->
                <Border x:Name="DropZone" Background="Transparent"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="2" CornerRadius="12" Margin="24"
                        Visibility="Visible">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="80" Height="80" Background="#1A2540" CornerRadius="40"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="&#x1F3AC;" FontSize="36"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Glissez vos fichiers ici"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Foreground="{StaticResource TextSecondary}"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Run Text="Formats support&#233;s : "/>
                            <Run Text="MXF, MP4, MOV, MKV, AVI, WMV, FLV..."
                                 Foreground="{StaticResource AccentBlue}"/>
                        </TextBlock>
                        <Button Style="{StaticResource PrimaryButton}"
                                Click="BtnAddFiles_Click" HorizontalAlignment="Center">
                            Parcourir les fichiers
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Liste des fichiers -->
                <Grid x:Name="FileListPanel" Visibility="Collapsed" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- En-têtes -->
                    <Grid Grid.Row="0" Margin="8,0,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="FICHIER"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="TAILLE"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="DUR&#201;E"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="FORMAT SORTIE"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="QUALIT&#201;"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="5" Text="PROGRESSION"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                        <TextBlock Grid.Column="6" Text="ACTIONS"
                                   Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold"/>
                    </Grid>

                    <!-- Liste scrollable -->
                    <ScrollViewer Grid.Row="1">
                        <ListBox x:Name="FileListBox" Background="Transparent"
                                 BorderThickness="0" Padding="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ConversionItem}">
                                    <Border Background="{StaticResource BgCard}"
                                            CornerRadius="8" Margin="0,0,0,6"
                                            Padding="8,10"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="110"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Nom fichier -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Background="#1A2540" CornerRadius="4"
                                                            Padding="5,2" VerticalAlignment="Center"
                                                            Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding FileExtension}"
                                                                   Foreground="{StaticResource AccentBlue}"
                                                                   FontSize="10" FontWeight="Bold"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding FileName}"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               FontSize="13" FontWeight="Medium"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding VideoInfo}"
                                                           Foreground="{StaticResource TextMuted}"
                                                           FontSize="10" Margin="0,3,0,0"/>
                                            </StackPanel>

                                            <!-- Taille -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding FileSizeFormatted}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="12"/>

                                            <!-- Durée -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding DurationFormatted}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="12"/>

                                            <!-- Format sortie -->
                                            <ComboBox Grid.Column="3" Width="100"
                                                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.Formats}"
                                                      SelectedItem="{Binding OutputFormat, Mode=TwoWay}"
                                                      VerticalAlignment="Center" FontSize="11"/>

                                            <!-- Qualité -->
                                            <ComboBox Grid.Column="4" Width="120"
                                                      ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.QualityPresets}"
                                                      SelectedItem="{Binding QualityPreset, Mode=TwoWay}"
                                                      VerticalAlignment="Center" FontSize="11"/>

                                            <!-- Progression -->
                                            <StackPanel Grid.Column="5" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <Ellipse Style="{StaticResource StatusDot}"
                                                             Fill="{Binding StatusColor}"
                                                             Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding ProgressText}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{Binding StatusColor}"/>
                                                </StackPanel>
                                                <ProgressBar Value="{Binding Progress}"
                                                             Maximum="100" Margin="0,0,0,3"/>
                                                <TextBlock Text="{Binding StatusMessage}"
                                                           FontSize="9"
                                                           Foreground="{StaticResource TextMuted}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- Actions -->
                                            <StackPanel Grid.Column="6" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Style="{StaticResource SecondaryButton}"
                                                        Padding="8,5" FontSize="11"
                                                        IsEnabled="{Binding CanConvert}"
                                                        Tag="{Binding Id}"
                                                        Click="BtnConvertOne_Click"
                                                        Margin="0,0,4,0">&#x25B6;</Button>
                                                <Button Style="{StaticResource SecondaryButton}"
                                                        Padding="8,5" FontSize="11"
                                                        IsEnabled="{Binding CanCancel}"
                                                        Tag="{Binding Id}"
                                                        Click="BtnCancelOne_Click"
                                                        Margin="0,0,4,0">&#x25A0;</Button>
                                                <Button Style="{StaticResource DangerButton}"
                                                        Padding="8,5" FontSize="11"
                                                        Tag="{Binding Id}"
                                                        Click="BtnRemoveOne_Click">&#x2715;</Button>
                                            </StackPanel>

                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <!-- Résumé bas -->
                    <Border Grid.Row="2" Background="{StaticResource BgCard}"
                            CornerRadius="8" Padding="16,10" Margin="0,8,0,0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                    <TextBlock Text="&#x1F4C4;" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="TxtTotalFiles"
                                               Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreen}"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="TxtCompleted"
                                               Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentOrange}"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="TxtPending"
                                               Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentRed}"
                                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="TxtErrors"
                                               Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                <TextBlock x:Name="TxtGlobalProgress"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="12" Margin="0,0,12,0"/>
                                <ProgressBar x:Name="GlobalProgressBar" Width="200"
                                             Maximum="100" Height="8" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- ===== BARRE DE STATUT ===== -->
            <Border Grid.Row="3" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12" Padding="16,8">
                <Grid>
                    <TextBlock x:Name="TxtStatus"
                               Text="Pr&#234;t &#8212; Glissez des fichiers ou cliquez sur Ajouter"
                               Foreground="{StaticResource TextMuted}" FontSize="11"
                               VerticalAlignment="Center"/>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <TextBlock Text="FFmpeg Engine"
                                   Foreground="{StaticResource TextMuted}" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Ellipse x:Name="FFmpegStatusDot" Width="7" Height="7"
                                 Fill="{StaticResource AccentGreen}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
