<Window x:Class="MXFConverter.Views.AdvancedOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Options avancées"
        Width="480" Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgPrimary}"
        Foreground="{StaticResource TextPrimary}"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- Titre -->
            <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                    CornerRadius="10,10,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x2699;" FontSize="14" Foreground="{StaticResource AccentBlue}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TxtTitle" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="&#x2715;" HorizontalAlignment="Right" Width="32" Height="28"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextSecondary}" Cursor="Hand"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- Contenu -->
            <ScrollViewer Grid.Row="1" Margin="24,16">
                <StackPanel>

                    <!-- Résolution -->
                    <TextBlock Text="VID&#201;O" Foreground="{StaticResource AccentBlue}"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="R&#233;solution" Foreground="{StaticResource TextPrimary}"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="CmbResolution" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Résolution personnalisée -->
                    <Grid x:Name="CustomResGrid" Margin="0,0,0,12" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Dimensions (px)" Foreground="{StaticResource TextSecondary}"
                                   FontSize="12" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="TxtWidth" Text="1920"
                                 Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                                 BorderBrush="{StaticResource BorderBrush}" Padding="6,4" FontSize="12"/>
                        <TextBlock Grid.Column="2" Text="×" Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="3" x:Name="TxtHeight" Text="1080"
                                 Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                                 BorderBrush="{StaticResource BorderBrush}" Padding="6,4" FontSize="12"/>
                    </Grid>

                    <!-- Framerate -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Fr&#233;quence d'images (fps)" Foreground="{StaticResource TextPrimary}"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="CmbFramerate" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Rotation -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Rotation / Miroir" Foreground="{StaticResource TextPrimary}"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" x:Name="CmbRotation" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Débit vidéo -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="D&#233;bit vid&#233;o personnalis&#233;" Foreground="{StaticResource TextPrimary}"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" x:Name="ChkVideoBitrate" VerticalAlignment="Center"
                                  Margin="0,0,8,0" Checked="ChkVideoBitrate_Changed" Unchecked="ChkVideoBitrate_Changed"/>
                        <TextBox Grid.Column="2" x:Name="TxtVideoBitrate" Text="5000"
                                 IsEnabled="False"
                                 Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                                 BorderBrush="{StaticResource BorderBrush}" Padding="6,4" FontSize="12"/>
                    </Grid>
                    <TextBlock Text="kbps — valeur recommand&#233;e : 2000–8000 pour 1080p"
                               Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,0,0,12"/>

                    <Separator/>

                    <!-- Rognage temporel -->
                    <TextBlock Text="ROGNAGE TEMPOREL" Foreground="{StaticResource AccentBlue}"
                               FontSize="10" FontWeight="Bold" Margin="0,8,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Activer le rognage" Foreground="{StaticResource TextPrimary}"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" x:Name="ChkTrim" VerticalAlignment="Center"
                                  Checked="ChkTrim_Changed" Unchecked="ChkTrim_Changed"/>
                    </Grid>

                    <Grid x:Name="TrimGrid" Visibility="Collapsed" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="D&#233;but (secondes)" Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtTrimStart" Text="0"
                                     Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                                     BorderBrush="{StaticResource BorderBrush}" Padding="6,4" FontSize="12"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="→" Foreground="{StaticResource TextMuted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Fin (secondes)" Foreground="{StaticResource TextSecondary}"
                                       FontSize="11" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtTrimEnd" Text="0"
                                     Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                                     BorderBrush="{StaticResource BorderBrush}" Padding="6,4" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <Separator/>

                    <!-- Audio -->
                    <TextBlock Text="AUDIO" Foreground="{StaticResource AccentBlue}"
                               FontSize="10" FontWeight="Bold" Margin="0,8,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="D&#233;bit audio personnalis&#233; (kbps)" Foreground="{StaticResource TextPrimary}"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" x:Name="ChkAudioBitrate" VerticalAlignment="Center"
                                  Margin="0,0,8,0" Checked="ChkAudioBitrate_Changed" Unchecked="ChkAudioBitrate_Changed"/>
                        <TextBox Grid.Column="2" x:Name="TxtAudioBitrate" Text="192"
                                 IsEnabled="False"
                                 Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                                 BorderBrush="{StaticResource BorderBrush}" Padding="6,4" FontSize="12"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Supprimer la piste audio" Foreground="{StaticResource TextPrimary}"
                                   FontSize="13" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" x:Name="ChkRemoveAudio" VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>

            <!-- Boutons -->
            <Border Grid.Row="2" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="16,0">
                    <Button Content="R&#233;initialiser" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0" Click="BtnReset_Click"/>
                    <Button Content="Annuler" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0" Click="BtnClose_Click"/>
                    <Button Content="Appliquer" Style="{StaticResource PrimaryButton}"
                            Click="BtnApply_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
