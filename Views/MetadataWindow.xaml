<Window x:Class="MXFConverter.Views.MetadataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Métadonnées"
        Width="440" Height="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgPrimary}"
        Foreground="{StaticResource TextPrimary}"
        WindowStyle="None" AllowsTransparency="True">

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                    CornerRadius="10,10,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x1F3F7;" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TxtTitle" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="&#x2715;" HorizontalAlignment="Right" Width="32" Height="28"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextSecondary}" Cursor="Hand"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="24,16">
                <TextBlock Text="Ces métadonnées seront intégrées dans le fichier converti."
                           Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,16"
                           TextWrapping="Wrap"/>

                <!-- Champs -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Titre" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="TxtMetaTitle"
                             Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="8,5" FontSize="12"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Auteur" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="TxtMetaAuthor"
                             Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="8,5" FontSize="12"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Description" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="TxtMetaDesc"
                             Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="8,5" FontSize="12"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Copyright" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="TxtMetaCopyright"
                             Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="8,5" FontSize="12"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Année" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="TxtMetaYear"
                             Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="8,5" FontSize="12"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="Commentaire" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="TxtMetaComment"
                             Background="{StaticResource BgCard}" Foreground="{StaticResource TextPrimary}"
                             BorderBrush="{StaticResource BorderBrush}" Padding="8,5" FontSize="12"/>
                </Grid>
            </StackPanel>

            <Border Grid.Row="2" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="16,0">
                    <Button Content="Effacer" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0" Click="BtnClear_Click"/>
                    <Button Content="Annuler" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0" Click="BtnClose_Click"/>
                    <Button Content="Enregistrer" Style="{StaticResource PrimaryButton}"
                            Click="BtnSave_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
