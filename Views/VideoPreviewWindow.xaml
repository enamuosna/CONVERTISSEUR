<Window x:Class="MXFConverter.Views.VideoPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prévisualisation — MXF Converter Pro"
        Width="1000" Height="680"
        MinWidth="800" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimary}"
        Foreground="{StaticResource TextPrimary}"
        WindowStyle="None"
        AllowsTransparency="True"
        Closed="Window_Closed">

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="52"/>
            </Grid.RowDefinitions>

            <!-- TITRE -->
            <Border Grid.Row="0" Background="{StaticResource BgSecondary}"
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x25B6;" FontSize="14" Foreground="{StaticResource AccentBlue}"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TxtWindowTitle" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <Border Background="#1A2540" CornerRadius="4" Padding="8,2" Margin="12,0,0,0">
                            <TextBlock x:Name="TxtResolution" Foreground="{StaticResource AccentBlue}" FontSize="10"/>
                        </Border>
                        <Border Background="#1A2540" CornerRadius="4" Padding="8,2" Margin="6,0,0,0">
                            <TextBlock x:Name="TxtCodecInfo" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                        </Border>
                    </StackPanel>
                    <Button Content="&#x2715;" HorizontalAlignment="Right" Width="32" Height="28"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextSecondary}" Cursor="Hand"
                            Click="BtnClose_Click"/>
                </Grid>
            </Border>

            <!-- ZONE VIDEO -->
            <Border Grid.Row="1" Background="#000000">
                <Grid>
                    <MediaElement x:Name="Player" LoadedBehavior="Manual" UnloadedBehavior="Stop"
                                  Stretch="Uniform" MediaOpened="Player_MediaOpened"
                                  MediaEnded="Player_MediaEnded" MediaFailed="Player_MediaFailed"/>
                    <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="12,10" Orientation="Horizontal">
                        <Border x:Name="PlayingBadge" Background="#CC000000" CornerRadius="4"
                                Padding="8,3" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="EN LECTURE" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Left"
                            Margin="12,0,0,8" Background="#CC000000" CornerRadius="4" Padding="8,3">
                        <TextBlock x:Name="TxtTimecode" Text="00:00:00 / 00:00:00"
                                   Foreground="White" FontSize="12" FontFamily="Courier New" FontWeight="SemiBold"/>
                    </Border>
                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Right"
                            Margin="0,0,12,8" Background="#CC000000" CornerRadius="4" Padding="8,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtVolumeIcon" Text="&#x1F50A;" FontSize="12"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Slider x:Name="SldVolume" Width="80" Minimum="0" Maximum="1" Value="1"
                                    VerticalAlignment="Center" ValueChanged="SldVolume_ValueChanged"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="TxtLoading" Text="Chargement..." Foreground="{StaticResource TextSecondary}"
                               FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <StackPanel x:Name="ErrorPanel" VerticalAlignment="Center"
                                HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="&#x26A0;" FontSize="40" HorizontalAlignment="Center"
                                   Foreground="{StaticResource AccentOrange}"/>
                        <TextBlock x:Name="TxtError" Foreground="{StaticResource TextSecondary}"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- TIMELINE -->
            <Border Grid.Row="2" Background="#0D1117" Padding="16,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <!-- Fond cliquable -->
                        <Border Background="#1C2230" CornerRadius="4" Height="36"
                                MouseLeftButtonDown="Timeline_MouseDown"
                                MouseMove="Timeline_MouseMove"
                                MouseLeftButtonUp="Timeline_MouseUp"
                                Cursor="Hand"/>
                        <!-- Canvas pour positionner les marqueurs avec Canvas.SetLeft -->
                        <Canvas x:Name="TimelineCanvas" Height="36">
                            <Border x:Name="TrimZone" Background="#1A3A6A" CornerRadius="2" Height="36" Opacity="0.7"/>
                            <Border x:Name="PlayHead" Width="3" Height="36"
                                    Background="{StaticResource AccentBlue}" CornerRadius="2">
                                <Border.Effect>
                                    <DropShadowEffect Color="#3B82F6" BlurRadius="6" ShadowDepth="0"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="MarkerStart" Width="3" Height="36"
                                    Background="#22C55E" CornerRadius="2" Cursor="SizeWE"
                                    MouseLeftButtonDown="MarkerStart_MouseDown">
                                <Border.ToolTip><ToolTip><TextBlock x:Name="TipStart" Text="Debut rognage"/></ToolTip></Border.ToolTip>
                            </Border>
                            <Border x:Name="MarkerEnd" Width="3" Height="36"
                                    Background="#EF4444" CornerRadius="2" Cursor="SizeWE"
                                    MouseLeftButtonDown="MarkerEnd_MouseDown">
                                <Border.ToolTip><ToolTip><TextBlock x:Name="TipEnd" Text="Fin rognage"/></ToolTip></Border.ToolTip>
                            </Border>
                        </Canvas>
                        <Canvas x:Name="TimeLabels" Height="14" Margin="0,40,0,0"/>
                    </Grid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Border Width="10" Height="10" Background="{StaticResource AccentBlue}" CornerRadius="2" Margin="0,0,5,0"/>
                        <TextBlock Text="Tete de lecture" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <Border Width="10" Height="10" Background="#22C55E" CornerRadius="2" Margin="0,0,5,0"/>
                        <TextBlock Text="Debut rognage (I)" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <Border Width="10" Height="10" Background="#EF4444" CornerRadius="2" Margin="0,0,5,0"/>
                        <TextBlock Text="Fin rognage (O)" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <Border Width="10" Height="10" Background="#1A3A6A" CornerRadius="2" Margin="0,0,5,0"/>
                        <TextBlock Text="Zone a conserver" Foreground="{StaticResource TextMuted}" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTROLES -->
            <Border Grid.Row="3" Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,1" Padding="16,10">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource SecondaryButton}" Click="BtnGoStart_Click" Padding="10,7" Margin="0,0,4,0"><TextBlock Text="&#x23EE;" FontSize="14"/></Button>
                        <Button Style="{StaticResource SecondaryButton}" Click="BtnBack5_Click" Padding="10,7" Margin="0,0,4,0"><TextBlock Text="&#x23F4;5s" FontSize="11"/></Button>
                        <Button x:Name="BtnPlayPause" Click="BtnPlayPause_Click" Padding="18,9" Margin="0,0,4,0" Style="{StaticResource PrimaryButton}">
                            <TextBlock x:Name="TxtPlayIcon" Text="&#x25B6;" FontSize="16"/>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Click="BtnFwd5_Click" Padding="10,7" Margin="0,0,4,0"><TextBlock Text="5s&#x23F5;" FontSize="11"/></Button>
                        <Button Style="{StaticResource SecondaryButton}" Click="BtnGoEnd_Click" Padding="10,7" Margin="0,0,16,0"><TextBlock Text="&#x23ED;" FontSize="14"/></Button>
                        <Separator Width="1" Height="30" Margin="0,0,16,0"/>
                        <TextBlock Text="Vitesse :" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,8,0"/>
                        <ComboBox x:Name="CmbSpeed" Width="110" SelectionChanged="CmbSpeed_SelectionChanged" VerticalAlignment="Center">
                            <ComboBoxItem Content="0.25x"/><ComboBoxItem Content="0.5x"/>
                            <ComboBoxItem Content="1x (normal)" IsSelected="True"/>
                            <ComboBoxItem Content="1.5x"/><ComboBoxItem Content="2x"/>
                        </ComboBox>
                        <Separator Width="1" Height="30" Margin="16,0"/>
                        <Button Style="{StaticResource SecondaryButton}" Click="BtnCapture_Click" Padding="10,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4F7;" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="Capture" VerticalAlignment="Center" FontSize="11"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <Border HorizontalAlignment="Right" Background="#0D1117" CornerRadius="6" Padding="12,6">
                        <TextBlock x:Name="TxtTimecodeRight" Text="00:00:00.000 / 00:00:00"
                                   Foreground="White" FontSize="13" FontFamily="Courier New" FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- EDITEUR ROGNAGE -->
            <Border Grid.Row="4" Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#0D2B1A" CornerRadius="8" Padding="12,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Width="10" Height="10" Background="#22C55E" CornerRadius="2" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="POINT DEBUT (IN)" Foreground="#22C55E" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="TxtTrimStart" Width="110" Background="#0A1A10" Foreground="#22C55E"
                                         BorderBrush="#1A5A30" Padding="8,6" FontSize="15" FontFamily="Courier New"
                                         FontWeight="Bold" TextChanged="TrimStart_TextChanged"/>
                                <StackPanel Margin="8,0,0,0">
                                    <Button Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="10" Margin="0,0,0,3" Click="BtnSetStart_Click">&#x25BC; Ici</Button>
                                    <Button Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="10" Click="BtnGoToStart_Click">&#x25BA; Aller</Button>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock x:Name="TxtStartLabel" Text="00:00:00" Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="DUREE SELECTION" Foreground="{StaticResource TextMuted}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtTrimDuration" Text="--:--:--" Foreground="{StaticResource AccentBlue}"
                                       FontSize="18" FontWeight="Bold" FontFamily="Courier New"
                                       HorizontalAlignment="Center" Margin="0,4,0,4"/>
                            <Button Style="{StaticResource SecondaryButton}" Padding="8,4" FontSize="10"
                                    Click="BtnClearTrim_Click" HorizontalAlignment="Center">&#x2715; Effacer</Button>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#2B0D0D" CornerRadius="8" Padding="12,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Border Width="10" Height="10" Background="#EF4444" CornerRadius="2" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="POINT FIN (OUT)" Foreground="#EF4444" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBox x:Name="TxtTrimEnd" Width="110" Background="#1A0A0A" Foreground="#EF4444"
                                         BorderBrush="#5A1A1A" Padding="8,6" FontSize="15" FontFamily="Courier New"
                                         FontWeight="Bold" TextChanged="TrimEnd_TextChanged"/>
                                <StackPanel Margin="8,0,0,0">
                                    <Button Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="10" Margin="0,0,0,3" Click="BtnSetEnd_Click">&#x25BC; Ici</Button>
                                    <Button Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="10" Click="BtnGoToEnd_Click">&#x25BA; Aller</Button>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock x:Name="TxtEndLabel" Text="00:00:00" Foreground="{StaticResource TextMuted}" FontSize="9" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Center">
                        <StackPanel>
                            <Button Style="{StaticResource PrimaryButton}" Padding="14,10" Click="BtnApplyTrim_Click">
                                <StackPanel>
                                    <TextBlock Text="&#x2705;" FontSize="16" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Appliquer" FontSize="11" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Text="sur ce fichier" Foreground="{StaticResource TextMuted}" FontSize="9" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- BARRE BAS -->
            <Border Grid.Row="5" Background="{StaticResource BgSecondary}" CornerRadius="0,0,12,12" Padding="16,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Raccourcis : " Foreground="{StaticResource TextMuted}" FontSize="10"/>
                        <Border Background="#1C2230" CornerRadius="3" Padding="5,2" Margin="4,0"><TextBlock Text="Espace" Foreground="{StaticResource TextSecondary}" FontSize="10"/></Border>
                        <TextBlock Text="lecture" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="4,0,10,0"/>
                        <Border Background="#1C2230" CornerRadius="3" Padding="5,2" Margin="0,0,4,0"><TextBlock Text="I" Foreground="{StaticResource AccentGreen}" FontSize="10" FontWeight="Bold"/></Border>
                        <TextBlock Text="IN" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,0,10,0"/>
                        <Border Background="#1C2230" CornerRadius="3" Padding="5,2" Margin="0,0,4,0"><TextBlock Text="O" Foreground="{StaticResource AccentRed}" FontSize="10" FontWeight="Bold"/></Border>
                        <TextBlock Text="OUT" Foreground="{StaticResource TextMuted}" FontSize="10" Margin="0,0,10,0"/>
                        <Border Background="#1C2230" CornerRadius="3" Padding="5,2" Margin="0,0,4,0"><TextBlock Text="&#x2190;  &#x2192;" Foreground="{StaticResource TextSecondary}" FontSize="10"/></Border>
                        <TextBlock Text="+-5s" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtBottomStatus" Text="Pret" HorizontalAlignment="Right"
                               Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
